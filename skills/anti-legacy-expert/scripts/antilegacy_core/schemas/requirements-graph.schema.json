{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "requirements-graph.schema.json",
  "title": "anti-legacy Requirements Graph",
  "description": "Output of graph_normalizer.py (raw 'draft' profile). Language-agnostic requirements organized by business domains. business_rules / validations / error_paths are first-class, ID'd items but OPTIONAL in this base profile so raw normalizer output (no rules) AND enriched output (with rules) both validate. The enriched overlay schemas/requirements-graph.enriched.schema.json tightens these to REQUIRED after enrich_requirements.py runs. ID CONVENTION: RULE-/VAL-/ERR- + three-to-six-digit zero-padded, UNIQUE WITHIN A REQUIREMENT (ids restart per requirement; the canonical global key is legacy_component+id, e.g. '<source_app>:<program>#RULE-002'). A validation's error_ref points at an ERR id in the SAME requirement (this intra-req join is what the round-trip done-check uses to verify a validation maps to a handled error path). IDs wider than 3 digits (e.g. RULE-001234) are emitted automatically when a community is large enough that sub-partitioning still yields >999 members.",
  "type": "object",
  "required": ["domains"],
  "$defs": {
    "rule": {
      "description": "A single business rule. During the string->object transition a raw 'RULE-001: <statement>' string still validates; producers (enrich_requirements.py) must emit the object form.",
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["id", "statement"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "pattern": "^RULE-[0-9]{3,6}$" },
            "statement": { "type": "string", "minLength": 1 },
            "source_ref": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "provenance": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source_app": { "type": "string" },
                "program": { "type": "string" },
                "ref": { "type": "string" }
              }
            }
          }
        }
      ]
    },
    "validation": {
      "description": "A single input/field validation. error_ref points at an ERR id in the SAME requirement.",
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["id", "statement"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "pattern": "^VAL-[0-9]{3,6}$" },
            "statement": { "type": "string", "minLength": 1 },
            "field": { "type": "string" },
            "error_ref": { "type": "string", "pattern": "^ERR-[0-9]{3,6}$" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "provenance": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source_app": { "type": "string" },
                "program": { "type": "string" },
                "ref": { "type": "string" }
              }
            }
          }
        }
      ]
    },
    "errorPath": {
      "description": "A single handled error path. code is the legacy/return code surfaced to the caller.",
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["id", "statement"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "pattern": "^ERR-[0-9]{3,6}$" },
            "statement": { "type": "string", "minLength": 1 },
            "code": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "provenance": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source_app": { "type": "string" },
                "program": { "type": "string" },
                "ref": { "type": "string" }
              }
            }
          }
        }
      ]
    }
  },
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["migration_mode"],
      "properties": {
        "migration_mode": { "type": "string", "enum": ["structural", "functional"] }
      }
    },
    "domains": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["requirements", "entities"],
        "properties": {
          "requirements": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["title", "description", "legacy_components", "data_access", "dependencies"],
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "legacy_components": { "type": "array", "items": { "type": "string" } },
                "data_access": { "type": "array", "items": { "type": "string" } },
                "dependencies": { "type": "array", "items": { "type": "string" } },
                "business_rules": { "type": "array", "items": { "$ref": "#/$defs/rule" } },
                "validations": { "type": "array", "items": { "$ref": "#/$defs/validation" } },
                "error_paths": { "type": "array", "items": { "$ref": "#/$defs/errorPath" } },
                "status": { "type": "string", "enum": ["active", "review", "unresolvable"] },
                "merged_programs": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "entities": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["description", "fields"],
              "properties": {
                "description": { "type": "string" },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type", "description"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
