# Ignore system files
.DS_Store
Thumbs.db

# Ignore Node dependencies
node_modules/
package-lock.json

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Ignore local build databases and caches (SQLite db)
*.db
*.db-shm
*.db-wal

# Ensure .anti-legacy directories are committed EXCEPT local cache databases
!.anti-legacy/
.anti-legacy/*.db
.anti-legacy/*.db-shm
.anti-legacy/*.db-wal

# Per-app wicked-estate code-graph DBs (rebuilt by survey via `wicked-estate index`) — never committed
.anti-legacy/graphs/

# KEEP committed (empty baselines, populated at runtime): the thin-seam evidence +
# the anti-legacy IP sidecars
!.anti-legacy/legacy-graph.digest.txt
!.anti-legacy/annotations.jsonl
!.anti-legacy/vocabulary.json

# Per-run pipeline output — regenerated per workspace by the pipeline, NEVER committed.
# Source-agnostic plugin: no test-repo (carddemo/credit-card) data baked into the repo.
.anti-legacy/requirements/
.anti-legacy/contracts/
.anti-legacy/coverage-report.json
.anti-legacy/coverage-report.md
.anti-legacy/evidence/
# Per-run vocabulary term->node bindings (drift seam, regenerated by `vocabulary
# project`; never committed — SymbolId/name sets are graph-derived, not IP).
.anti-legacy/vocabulary-bindings.json

# Workspace dispatcher — machine-specific (baked absolute plugin root), written by
# anti-legacy:setup per workspace; never committed.
.anti-legacy/run.py

# Cloned source repos (external, have their own .git) — never commit into the plugin
.anti-legacy/imports/
# Throwaway debug scratch
.anti-legacy/scratch/
