# Ignore system files
.DS_Store
Thumbs.db

# Ignore Node dependencies
node_modules/
package-lock.json

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Ignore local build databases and caches (SQLite db)
*.db
*.db-shm
*.db-wal

# The .anti-legacy/ workspace is a LOCAL test/scratch workspace only — NEVER committed.
# (Real workspaces are created per-project by anti-legacy:setup; this repo just uses one
# for local testing.) The shipped public demo graph that the eval-tier tests validate now
# lives under tests/evals/fixtures/real_demo_requirements_graph.json, not here.
.anti-legacy/

# Agent worktrees (temporary, per-agent git worktrees) — never commit
.claude/worktrees/
